# =============================================
# Pull API v2 - Environment Configuration
# Copy this to .env and fill in your values
# =============================================

# =============================================
# SERVER
# =============================================
PORT=8080
ENVIRONMENT=development
# Use http://localhost:3000 for local frontend development
FRONTEND_URL=http://localhost:3000
# Comma-separated origins allowed for CORS (development mode allows all)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# =============================================
# CENTRAL DATABASE (Pull Platform)
# This is the master database that stores:
# - Venue registry
# - Database configs per venue
# - Payment gateway configs per venue
# - Platform transactions/fees
# =============================================
CENTRAL_SUPABASE_URL=https://your-central-project.supabase.co
CENTRAL_SERVICE_KEY=your-central-service-key
CENTRAL_ANON_KEY=your-central-anon-key

# =============================================
# DEFAULT VENUE DATABASE (Legacy/Fallback)
# Used when multi-tenant is disabled or as fallback
# =============================================
DEFAULT_SUPABASE_URL=https://your-default-venue.supabase.co
DEFAULT_SERVICE_KEY=your-default-service-key
DEFAULT_ANON_KEY=your-default-anon-key

# Legacy compatibility (maps to DEFAULT_*)
SUPABASE_URL=https://your-default-venue.supabase.co
SUPABASE_SERVICE_KEY=your-default-service-key
SUPABASE_ANON_KEY=your-default-anon-key

# =============================================
# SECURITY
# =============================================
# JWT Secret - minimum 32 characters in production
# For development, any string works
JWT_SECRET=dev-secret-key-change-in-production-minimum-32-chars

# App Key - exactly 64 hex characters (32 bytes for AES-256)
# Generate with: openssl rand -hex 32
# For development, use this placeholder:
APP_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# =============================================
# STRIPE (Platform account)
# =============================================
# Use Stripe test keys for development
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================
# EMAIL (Resend)
# =============================================
# Leave empty in development to log emails instead of sending
RESEND_API_KEY=
RESEND_FROM_EMAIL=Pull Events <noreply@localhost>

# =============================================
# OPTIONAL SERVICES
# =============================================
REDIS_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cookie settings
COOKIE_SAMESITE=Lax

# =============================================
# DEVELOPMENT VS PRODUCTION
# =============================================
#
# DEVELOPMENT MODE (ENVIRONMENT=development):
# ✓ CORS allows ALL origins (localhost, etc.)
# ✓ IP blocking is lenient (20 failures to block)
# ✓ Localhost IPs are never blocked
# ✓ Error details shown in API responses
# ✓ HSTS header not sent
# ✓ Relaxed JWT_SECRET/APP_KEY validation
# ✓ Emails are logged instead of sent (if no RESEND_API_KEY)
#
# PRODUCTION MODE (ENVIRONMENT=production):
# ✗ CORS only allows ALLOWED_ORIGINS
# ✗ IP blocking after 5 failed attempts
# ✗ Strict JWT_SECRET (32+ chars required)
# ✗ Strict APP_KEY (64 hex chars required)
# ✗ Error details hidden
# ✗ HSTS header enabled
# ✗ STRIPE_WEBHOOK_SECRET required
#
# =============================================
