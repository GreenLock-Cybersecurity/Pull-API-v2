# =============================================================================
# Pull-API-v2 — environment variables template
# =============================================================================
#
# Copy this file to `.env` (gitignored) and fill in real values.
# Real secrets never go to git.
#
# The Aurora Hall demo has the live values stored as Fly.io secrets on app
# `pull-api-v2-demo`. To recover them:
#
#   flyctl secrets list --app pull-api-v2-demo   # names + digests only
#   flyctl ssh console --app pull-api-v2-demo    # then `env | grep <NAME>`
#
# Fly does NOT expose secret values in `secrets list`. Options to recover
# real values on a new machine:
#   1. `flyctl ssh console` + `env | grep <NAME>` on the running Fly VM.
#   2. Read them from the Supabase / Cloudflare / Brevo dashboards.
#   3. Ask a teammate — they're in your team's shared password manager.
#
# =============================================================================

# ---------- APP ----------

# Runtime. Change to `development` for extra logging + lenient CORS.
ENVIRONMENT=production

# HTTP port. `fly.toml [http_service] internal_port` must match.
PORT=8080

# Enable the mock Stripe processor (services/mock_processor.go).
# ALWAYS true in the Aurora Hall demo.
DEMO_MODE=true

# JWT signing secret. Any random 32+ char string.
#   openssl rand -hex 32
# CRITICAL: rotating this invalidates every issued JWT (all staff sessions).
JWT_SECRET=

# AES-256-GCM key for encrypting/decrypting venue Supabase credentials in
# the central DB. MUST be exactly 64 hex chars (256 bits).
#   openssl rand -hex 32
# CRITICAL: rotating this makes every stored `venue_database_configs` row
# unreadable. Only rotate if you plan to re-encrypt every venue row.
APP_KEY=

# CORS. Comma-separated list of allowed origins.
ALLOWED_ORIGINS=https://aurora-hall.pages.dev,https://pull-api-v2-demo.fly.dev

# Customer-facing WebApp base URL. Used in email templates + redirects.
FRONTEND_URL=https://aurora-hall.pages.dev

# Public URL of this API. Used in email links.
API_BASE_URL=https://pull-api-v2-demo.fly.dev

# Cookie SameSite. `None` for cross-origin auth cookies (requires HTTPS).
COOKIE_SAMESITE=None

# ---------- CENTRAL DB (Pull platform Supabase) ----------
# Holds `venues`, encrypted per-venue DB credentials, platform-level rows.
# One instance, shared across all tenants.

# https://<project-ref>.supabase.co
# Supabase dashboard → Project Settings → API → Project URL.
CENTRAL_SUPABASE_URL=https://dqqvtehpidihahzabcxg.supabase.co

# service_role key. Full RW access. NEVER ship to a browser.
# Supabase → Project Settings → API → service_role.
CENTRAL_SERVICE_KEY=

# anon key. Public-safe.
CENTRAL_ANON_KEY=

# ---------- DEFAULT VENUE DB (Aurora Hall demo) ----------
# The venue Supabase used by legacy compat paths as the "single-tenant
# fallback". In the Aurora demo it points at Aurora's own Supabase.

DEFAULT_SUPABASE_URL=https://oqqhffxwiizukkevzkvz.supabase.co
DEFAULT_SERVICE_KEY=
DEFAULT_ANON_KEY=

# Legacy aliases (v1 code that reads these instead of the DEFAULT_* set).
# Set them to the same values.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# ---------- REDIS (optional) ----------
# Used for rate-limiting and cache. Empty → in-memory (fine on single Fly
# machine; NOT fine if you scale to multiple machines).
REDIS_URL=

# ---------- EMAIL ----------

# Brevo (transactional) — the primary email provider.
# 300 emails/day free, no domain verification required.
# https://app.brevo.com/settings/keys/api → create key (`xkeysib-...`).
BREVO_API_KEY=
BREVO_FROM_EMAIL=Pull Events <noreply@tickets.pullevents.com>

# Resend (fallback / legacy). Kept for backward-compat, unused in demo.
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=Pull Events <noreply@tickets.pullevents.com>

# ---------- STRIPE (only if DEMO_MODE=false) ----------
# In the Aurora Hall demo the mock processor is used instead. These can
# stay empty for the demo.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------- GOOGLE OAUTH (optional) ----------
# Only used if you enable Google login for customers. Not wired in demo.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# DEVELOPMENT vs PRODUCTION notes
# =============================================================================
#
# DEVELOPMENT (ENVIRONMENT=development):
#   ✓ CORS allows ALL origins
#   ✓ IP block threshold raised to 20 failures
#   ✓ Localhost IPs never blocked
#   ✓ Error details in JSON responses
#   ✓ HSTS disabled
#   ✓ JWT_SECRET/APP_KEY validation relaxed (any string OK)
#   ✓ Emails logged instead of sent when RESEND_API_KEY is empty
#
# PRODUCTION (ENVIRONMENT=production):
#   ✗ Only ALLOWED_ORIGINS allowed
#   ✗ IP block after 5 failures
#   ✗ JWT_SECRET must be ≥32 chars
#   ✗ APP_KEY must be exactly 64 hex chars
#   ✗ Error details redacted
#   ✗ HSTS enabled
#   ✗ STRIPE_WEBHOOK_SECRET required when DEMO_MODE=false
#
# =============================================================================
